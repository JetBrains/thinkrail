{
	"name": "@thinkrail-pi/cli",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"bin": {
		"thinkrail-pi": "./src/index.ts"
	},
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"build:binary": "bun run scripts/build-binary.ts",
		"smoke:binary": "bun run scripts/smoke-binary.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@thinkrail-pi/server": "workspace:*",
		"@thinkrail-pi/shared": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	}
}
