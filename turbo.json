{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": ["THINKRAIL_*", "PI_CODING_AGENT_DIR", "WIRE_PROXY_PORT"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": [],
			"cache": false
		},
		"test": {
			"cache": false
		},
		"clean": {
			"cache": false
		}
	}
}
