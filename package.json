{
	"name": "@thinkrail-pi/monorepo",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:server": "turbo run dev --filter=@thinkrail-pi/server",
		"dev:web": "turbo run dev --filter=@thinkrail-pi/web",
		"build:web": "turbo run build --filter=@thinkrail-pi/web",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"lint": "biome check .",
		"format": "biome check --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"husky": "^9.1.7",
		"turbo": "^2.9.18",
		"typescript": "^6.0.3"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"esbuild"
	]
}
