{
  "name": "bonsai-e2e",
  "private": true,
  "version": "0.0.0",
  "description": "End-to-end tests for Bonsai (Playwright)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:electron": "playwright test --config electron/playwright.config.ts",
    "test:all": "npm test && npm run test:electron",
    "report": "playwright show-report",
    "report:electron": "playwright show-report ../playwright-report-electron"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0"
  }
}
