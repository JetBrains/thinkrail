node_modules/
dist/
.turbo/
*.tsbuildinfo
.DS_Store
.idea/
test-results/
playwright-report/
blob-report/
playwright/.cache/
e2e/screenshots/

docs/*
.playwright-mcp/
.claude/

# Per-workspace ephemeral scratch for temp docs (task-specs, working files). The host also seeds a
# self-ignoring .thinkrail/context/.gitignore in every worktree; scoped to context/ so the rest of
# .thinkrail/ stays free for future durable host files (e.g. a cached spec index).
.thinkrail/context/

# Build-only manifests written transiently by apps/cli/scripts/build-binary.ts
apps/cli/src/*.generated.ts

# Local env / secrets (Vite auto-loads .env*; app handles provider auth tokens)
.env
.env.local
.env.*.local
