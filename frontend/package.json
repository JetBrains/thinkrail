{
  "name": "bonsai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "tsc --noEmit && eslint src/",
    "generate:schema": "cd ../backend && uv run python -m app.cli export-schema -o ../frontend/openapi.json",
    "generate:api": "openapi-typescript openapi.json -o src/api/generated.ts",
    "generate:ws-schema": "cd ../backend && uv run python -m app.cli export-ws-schema -o ../frontend/ws-events.json",
    "generate:ws-types": "json2ts -i ws-events.json -o src/types/ws-events.ts --no-additionalProperties",
    "generate": "npm run generate:schema && npm run generate:api && npm run generate:ws-schema && npm run generate:ws-types"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@monaco-editor/react": "^4.7.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.55.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "dompurify": "^3.3.2"
  }
}
