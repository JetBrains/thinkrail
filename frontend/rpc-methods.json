{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThinkRailRpcPayloads",
  "$defs": {
    "LabeledOption": {
      "additionalProperties": false,
      "description": "A value the backend accepts, plus a display label for the UI.\n\nUsed uniformly for permission modes, effort levels, and models on\n``RuntimeCapabilities``. ``extra=\"forbid\"`` surfaces typos at parse time.",
      "properties": {
        "value": {
          "title": "Value",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "value",
        "label"
      ],
      "title": "LabeledOption",
      "type": "object"
    },
    "RuntimeFlag": {
      "additionalProperties": false,
      "description": "A runtime-declared option toggle, surfaced as a control in settings.\n\nEach runtime advertises its own flags; the frontend renders one control\nper flag and stores the chosen value in ``SessionConfig.flags`` keyed by\n``key``. ``type`` is a discriminator (only ``\"boolean\"`` today) so other\nvalue kinds can be added without changing the shape.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "type": {
          "const": "boolean",
          "title": "Type",
          "type": "string"
        },
        "default": {
          "type": "boolean",
          "title": "Default"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "key",
        "label",
        "type",
        "default"
      ],
      "title": "RuntimeFlag",
      "type": "object"
    },
    "RuntimeIdentity": {
      "additionalProperties": false,
      "description": "Lightweight ``{runtimeType, displayName}`` pair for ``runtimes/list``.",
      "properties": {
        "runtimeType": {
          "const": "claude",
          "title": "Runtimetype",
          "type": "string"
        },
        "displayName": {
          "title": "Displayname",
          "type": "string"
        }
      },
      "required": [
        "runtimeType",
        "displayName"
      ],
      "title": "RuntimeIdentity",
      "type": "object"
    },
    "RuntimeCapabilities": {
      "additionalProperties": false,
      "description": "What a runtime accepts for the user-tunable fields.\n\nOrder is contract: position 0 of ``permission_modes`` / ``effort_levels`` /\n``models`` is the runtime's default (cold-start picks ``[0].value``).",
      "properties": {
        "permissionModes": {
          "items": {
            "$ref": "#/$defs/LabeledOption"
          },
          "title": "Permissionmodes",
          "type": "array"
        },
        "effortLevels": {
          "items": {
            "$ref": "#/$defs/LabeledOption"
          },
          "title": "Effortlevels",
          "type": "array"
        },
        "models": {
          "items": {
            "$ref": "#/$defs/LabeledOption"
          },
          "title": "Models",
          "type": "array"
        },
        "flags": {
          "items": {
            "$ref": "#/$defs/RuntimeFlag"
          },
          "title": "Flags",
          "type": "array"
        }
      },
      "required": [
        "permissionModes",
        "effortLevels",
        "models"
      ],
      "title": "RuntimeCapabilities",
      "type": "object"
    },
    "RuntimesListResponse": {
      "additionalProperties": false,
      "description": "Wire payload returned by ``runtimes/list``.",
      "properties": {
        "runtimes": {
          "items": {
            "$ref": "#/$defs/RuntimeIdentity"
          },
          "title": "Runtimes",
          "type": "array"
        }
      },
      "required": [
        "runtimes"
      ],
      "title": "RuntimesListResponse",
      "type": "object"
    },
    "RuntimesCapabilitiesRequest": {
      "additionalProperties": false,
      "description": "Wire payload accepted by ``runtimes/capabilities``.",
      "properties": {
        "runtimeType": {
          "const": "claude",
          "title": "Runtimetype",
          "type": "string"
        }
      },
      "required": [
        "runtimeType"
      ],
      "title": "RuntimesCapabilitiesRequest",
      "type": "object"
    },
    "InvalidCapabilityValueData": {
      "additionalProperties": false,
      "description": "``data`` payload attached to ``INVALID_CAPABILITY_VALUE`` (-32032).",
      "properties": {
        "field": {
          "title": "Field",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        },
        "runtimeType": {
          "const": "claude",
          "title": "Runtimetype",
          "type": "string"
        },
        "allowed": {
          "items": {
            "type": "string"
          },
          "title": "Allowed",
          "type": "array"
        }
      },
      "required": [
        "field",
        "value",
        "runtimeType",
        "allowed"
      ],
      "title": "InvalidCapabilityValueData",
      "type": "object"
    },
    "SessionConfig": {
      "description": "Run configuration for a session.",
      "properties": {
        "runtime": {
          "const": "claude",
          "default": "claude",
          "title": "Runtime",
          "type": "string"
        },
        "model": {
          "default": "claude-opus-4-8",
          "title": "Model",
          "type": "string"
        },
        "permissionMode": {
          "default": "default",
          "title": "Permissionmode",
          "type": "string"
        },
        "streamText": {
          "default": true,
          "title": "Streamtext",
          "type": "boolean"
        },
        "effort": {
          "default": "auto",
          "title": "Effort",
          "type": "string"
        },
        "flags": {
          "additionalProperties": {
            "type": "boolean"
          },
          "title": "Flags",
          "type": "object"
        }
      },
      "title": "SessionConfig",
      "type": "object"
    },
    "ArtifactKind": {
      "enum": [
        "file",
        "diff"
      ],
      "title": "ArtifactKind",
      "type": "string"
    },
    "Artifact": {
      "description": "A file a session touched, or a diff it proposed.",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "created": {
          "default": "",
          "title": "Created",
          "type": "string"
        },
        "updated": {
          "default": "",
          "title": "Updated",
          "type": "string"
        }
      },
      "required": [
        "path",
        "kind"
      ],
      "title": "Artifact",
      "type": "object"
    },
    "SessionMetrics": {
      "description": "Run cost and usage, computed from the event stream.",
      "properties": {
        "costUsd": {
          "default": 0.0,
          "title": "Costusd",
          "type": "number"
        },
        "turns": {
          "default": 0,
          "title": "Turns",
          "type": "integer"
        },
        "toolCalls": {
          "default": 0,
          "title": "Toolcalls",
          "type": "integer"
        },
        "durationMs": {
          "default": 0,
          "title": "Durationms",
          "type": "integer"
        },
        "contextTokens": {
          "default": 0,
          "title": "Contexttokens",
          "type": "integer"
        },
        "contextMax": {
          "default": 0,
          "title": "Contextmax",
          "type": "integer"
        },
        "outputTokens": {
          "default": 0,
          "title": "Outputtokens",
          "type": "integer"
        }
      },
      "title": "SessionMetrics",
      "type": "object"
    },
    "TodoItem": {
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "status": {
          "default": "pending",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "key",
        "content"
      ],
      "title": "TodoItem",
      "type": "object"
    },
    "CreateTicketAction": {
      "description": "Queued ticket creation. Rendered as an 'Add to board' button.\n\n`state=\"pending\"` until the user clicks; `state=\"applied\"` once the ticket\nhas been created on the board.",
      "properties": {
        "type": {
          "const": "create_ticket",
          "default": "create_ticket",
          "title": "Type",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "body": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Body"
        },
        "state": {
          "default": "pending",
          "enum": [
            "pending",
            "applied"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title"
      ],
      "title": "CreateTicketAction",
      "type": "object"
    },
    "NavigateAction": {
      "description": "UI navigation only \u2014 no agent or tool call.",
      "properties": {
        "type": {
          "const": "navigate",
          "default": "navigate",
          "title": "Type",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "target": {
          "enum": [
            "board",
            "specs",
            "graph",
            "files"
          ],
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "target"
      ],
      "title": "NavigateAction",
      "type": "object"
    },
    "StartSessionAction": {
      "description": "Recommended follow-up session. Rendered as a primary/secondary CTA.",
      "properties": {
        "type": {
          "const": "start_session",
          "default": "start_session",
          "title": "Type",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "skillId": {
          "title": "Skillid",
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        },
        "primary": {
          "default": false,
          "title": "Primary",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "title",
        "skillId"
      ],
      "title": "StartSessionAction",
      "type": "object"
    },
    "SessionResult": {
      "description": "The value a session hands back to its parent, plus its done-screen.",
      "properties": {
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        },
        "delivery": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delivery"
        },
        "artifacts": {
          "items": {
            "$ref": "#/$defs/Artifact"
          },
          "title": "Artifacts",
          "type": "array"
        },
        "actions": {
          "items": {
            "discriminator": {
              "mapping": {
                "create_ticket": "#/$defs/CreateTicketAction",
                "navigate": "#/$defs/NavigateAction",
                "start_session": "#/$defs/StartSessionAction"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/CreateTicketAction"
              },
              {
                "$ref": "#/$defs/StartSessionAction"
              },
              {
                "$ref": "#/$defs/NavigateAction"
              }
            ]
          },
          "title": "Actions",
          "type": "array"
        }
      },
      "title": "SessionResult",
      "type": "object"
    },
    "NodeRun": {
      "properties": {
        "kind": {
          "enum": [
            "session",
            "subagent"
          ],
          "title": "Kind",
          "type": "string"
        },
        "sessionId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sessionid"
        },
        "orchestratorSid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Orchestratorsid"
        },
        "toolUseId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tooluseid"
        },
        "agentId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agentid"
        },
        "status": {
          "default": "running",
          "enum": [
            "running",
            "done",
            "failed",
            "cancelled"
          ],
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "usage": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Usage"
        }
      },
      "required": [
        "kind"
      ],
      "title": "NodeRun",
      "type": "object"
    },
    "OrchestrationConfig": {
      "description": "Per-ticket orchestration gates + failure policy (see design \u00a73).",
      "properties": {
        "stageGate": {
          "default": "approve",
          "enum": [
            "approve",
            "autonomous"
          ],
          "title": "Stagegate",
          "type": "string"
        },
        "stepGate": {
          "default": "approve",
          "enum": [
            "approve",
            "autonomous"
          ],
          "title": "Stepgate",
          "type": "string"
        },
        "failurePolicy": {
          "default": "fail-fast",
          "enum": [
            "fail-fast",
            "wait-all"
          ],
          "title": "Failurepolicy",
          "type": "string"
        },
        "stepExecution": {
          "default": "interactive",
          "enum": [
            "interactive",
            "subagent"
          ],
          "title": "Stepexecution",
          "type": "string"
        }
      },
      "title": "OrchestrationConfig",
      "type": "object"
    },
    "OrchestratorRef": {
      "description": "Reference to a ticket's orchestrator driver. ``kind=\"session\"`` points at a\nSession via ``session_id``; ``kind=\"builtin\"`` names a registered pipeline via\n``builtin_id``. See SESSION_TICKET_MODEL.md \u00a7\"The orchestrator\".",
      "properties": {
        "kind": {
          "default": "session",
          "enum": [
            "session",
            "builtin"
          ],
          "title": "Kind",
          "type": "string"
        },
        "sessionId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sessionid"
        },
        "builtinId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Builtinid"
        }
      },
      "title": "OrchestratorRef",
      "type": "object"
    },
    "SessionRef": {
      "properties": {
        "thinkrailSid": {
          "title": "Thinkrailsid",
          "type": "string"
        },
        "skillId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skillid"
        },
        "status": {
          "default": "",
          "title": "Status",
          "type": "string"
        },
        "name": {
          "default": "",
          "title": "Name",
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        }
      },
      "required": [
        "thinkrailSid"
      ],
      "title": "SessionRef",
      "type": "object"
    },
    "WorkNode": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "skill": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skill"
        },
        "dependsOn": {
          "items": {
            "type": "string"
          },
          "title": "Dependson",
          "type": "array"
        },
        "status": {
          "default": "pending",
          "enum": [
            "pending",
            "running",
            "done",
            "failed"
          ],
          "title": "Status",
          "type": "string"
        },
        "runs": {
          "items": {
            "$ref": "#/$defs/NodeRun"
          },
          "title": "Runs",
          "type": "array"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "artifactKind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifactkind"
        },
        "executesPlan": {
          "default": false,
          "title": "Executesplan",
          "type": "boolean"
        },
        "children": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/WorkNode"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Children"
        },
        "completedAt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completedat"
        }
      },
      "required": [
        "id",
        "title"
      ],
      "title": "WorkNode",
      "type": "object"
    },
    "TicketState": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "body": {
          "default": "",
          "title": "Body",
          "type": "string"
        },
        "type": {
          "default": "feature",
          "title": "Type",
          "type": "string"
        },
        "rev": {
          "default": 0,
          "title": "Rev",
          "type": "integer"
        },
        "lifecycle": {
          "default": "created",
          "enum": [
            "created",
            "design",
            "implementation",
            "done"
          ],
          "title": "Lifecycle",
          "type": "string"
        },
        "orchestrator": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrchestratorRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "orchestration": {
          "$ref": "#/$defs/OrchestrationConfig"
        },
        "stages": {
          "items": {
            "$ref": "#/$defs/WorkNode"
          },
          "title": "Stages",
          "type": "array"
        },
        "sessions": {
          "items": {
            "$ref": "#/$defs/SessionRef"
          },
          "title": "Sessions",
          "type": "array"
        },
        "linkedSpecIds": {
          "items": {
            "type": "string"
          },
          "title": "Linkedspecids",
          "type": "array"
        },
        "created": {
          "default": "",
          "title": "Created",
          "type": "string"
        },
        "updated": {
          "default": "",
          "title": "Updated",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title"
      ],
      "title": "TicketState",
      "type": "object"
    },
    "AnalyticsStatus": {
      "description": "Wire view of consent for the in-app toggle.\n\nEvery analytics event is stamped and sent backend-side, so the frontend\nnever needs the ``installation_id`` \u2014 only the ``enabled`` flag crosses\nthe wire. No default: the handler always sets it, so the field is required\non the wire (non-optional in the generated TypeScript).",
      "properties": {
        "enabled": {
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "AnalyticsStatus",
      "type": "object"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/LabeledOption"
    },
    {
      "$ref": "#/$defs/RuntimeFlag"
    },
    {
      "$ref": "#/$defs/RuntimeIdentity"
    },
    {
      "$ref": "#/$defs/RuntimeCapabilities"
    },
    {
      "$ref": "#/$defs/RuntimesListResponse"
    },
    {
      "$ref": "#/$defs/RuntimesCapabilitiesRequest"
    },
    {
      "$ref": "#/$defs/InvalidCapabilityValueData"
    },
    {
      "$ref": "#/$defs/SessionConfig"
    },
    {
      "$ref": "#/$defs/Artifact"
    },
    {
      "$ref": "#/$defs/SessionMetrics"
    },
    {
      "$ref": "#/$defs/TodoItem"
    },
    {
      "$ref": "#/$defs/SessionResult"
    },
    {
      "$ref": "#/$defs/TicketState"
    },
    {
      "$ref": "#/$defs/AnalyticsStatus"
    }
  ]
}